#!/bin/sh
# yank - copy input to tmux buffer and system clipboard via OSC 52
# Usage: yank < file
#        ... | yank

buf=$(cat)
[ -z "$buf" ] && exit 0

# Pick the pty to write OSC 52 to:
# - Outside tmux: /dev/tty is the caller's own pty (ssh/mosh/local terminal).
# - Inside tmux: /dev/tty is a tmux-internal pane pty that can't reach the
#   user's terminal directly, so find the pty of the real tmux client
#   instead. Two problems to solve:
#
#   1. Skip "nested" clients — ones spawned from within tmux itself (popups,
#      Claude Code's own `tmux attach`). Their tty is another internal pty.
#      Detect by walking the client PID's parent chain: if the tmux server
#      PID is an ancestor, the client was spawned from inside tmux.
#
#   2. Pick the right real client when several are attached (concurrent
#      mosh + ssh, stale mosh-server lingering after a network drop). Use
#      client_activity as the tiebreaker: the client you're typing in
#      right now had its activity bumped most recently; stale clients have
#      frozen timestamps.
if [ -z "$TMUX" ]; then
    tty=/dev/tty
else
    server_pid=$(tmux display-message -p '#{pid}')
    tty=$(tmux list-clients -F '#{client_activity} #{client_pid} #{client_tty}' \
        | sort -rn \
        | while read -r _cact cpid ctty; do
            pid=$cpid
            nested=0
            while [ "$pid" -gt 1 ] 2>/dev/null; do
                ppid=$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' ')
                [ -z "$ppid" ] && break
                if [ "$ppid" = "$server_pid" ]; then
                    nested=1
                    break
                fi
                pid=$ppid
            done
            if [ "$nested" = 0 ]; then
                printf '%s' "$ctty"
                break
            fi
        done)
    # Also populate tmux's own paste buffer so `prefix ]` works.
    printf '%s' "$buf" | tmux load-buffer - 2>/dev/null
fi

# Write OSC 52 directly to the selected pty. We avoid `tmux load-buffer -w`
# because its output path isn't reliably forwarded by mosh — some mosh
# versions silently drop escapes that come through tmux's emission path, but
# happily forward raw writes to the client pty.
#
# Silently tolerates failures: no controlling tty (nvim's jobstart child),
# no real client found, etc.
b64=$(printf '%s' "$buf" | base64 | tr -d '\n')
[ -n "$tty" ] && printf '\033]52;c;%s\a' "$b64" > "$tty" 2>/dev/null || true
