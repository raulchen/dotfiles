#!/bin/sh
# yank - copy input to tmux buffer and system clipboard via OSC 52
# Usage: yank < file
#        ... | yank

buf=$(cat)
[ -z "$buf" ] && exit 0

if [ -n "$TMUX" ]; then
    # Send OSC 52 to the tmux client the user is actually looking at, via
    # `load-buffer -w -t <client-tty>`. Two problems to solve:
    #
    # 1. Skip "nested" clients — ones spawned from within tmux itself (popups,
    #    Claude Code's own `tmux attach`). Their tty is an internal pty that
    #    can't reach any terminal. Detect by walking the client PID's parent
    #    chain: if the tmux server PID is an ancestor, it was spawned from
    #    inside tmux and is nested.
    #
    # 2. Pick the right real client when several are attached (e.g. concurrent
    #    mosh + ssh, or a stale mosh-server lingering after a network drop).
    #    Use client_activity as the tiebreaker: the client you're typing in
    #    right now had its activity bumped most recently; stale clients have
    #    frozen timestamps.
    server_pid=$(tmux display-message -p '#{pid}')  # tmux server PID
    tty=$(tmux list-clients -F '#{client_activity} #{client_pid} #{client_tty}' \
        | sort -rn \
        | while read -r _cact cpid ctty; do
            pid=$cpid
            nested=0
            while [ "$pid" -gt 1 ] 2>/dev/null; do  # walk towards PID 1 (init)
                ppid=$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' ')  # get parent PID
                [ -z "$ppid" ] && break  # process gone
                if [ "$ppid" = "$server_pid" ]; then
                    nested=1  # spawned from within tmux, its tty is a pane pty
                    break
                fi
                pid=$ppid  # move up one level
            done
            if [ "$nested" = 0 ]; then
                printf '%s' "$ctty"  # most recent real client
                break
            fi
        done)
    if [ -n "$tty" ]; then
        printf '%s' "$buf" | tmux load-buffer -w -t "$tty" - 2>/dev/null
    else
        printf '%s' "$buf" | tmux load-buffer -w - 2>/dev/null  # no real client found
    fi
fi

# Outside tmux, write OSC 52 directly to /dev/tty. This covers cases where
# yank is invoked from a non-tmux shell (e.g. over plain SSH). When invoked
# from a process without a controlling terminal (e.g. nvim's jobstart child),
# this silently fails — the tmux branch above handles that case.
if [ -z "$TMUX" ]; then
    b64=$(printf '%s' "$buf" | base64 | tr -d '\n')
    printf '\033]52;c;%s\a' "$b64" >/dev/tty 2>/dev/null || true
fi
